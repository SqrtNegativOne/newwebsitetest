---
layout: base.njk
---

<a href="/blog/" class="post-back">&larr; All posts</a>

<article>
  <header class="post-header">
    <h2 class="post-title">{{ title }}</h2>
    <time class="post-date">{{ date | readableDate }}</time>
  </header>
  <div class="post-body">
    {{ content | safe }}
  </div>
</article>
